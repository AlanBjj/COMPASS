# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Real environment variables take precedence over .env.

# LLM-as-judge for HR/Acc evaluation: the model is read from the run config
# (configs/*.yaml, default gpt-5.4-mini); endpoint is any OpenAI-compatible API.
OPENAI_BASE_URL=https://your-proxy.example/v1
OPENAI_API_KEY=sk-your-key-here

# Serper API key for FreshQA Fact-type retrieval (used by compass/solvers/rag_solver.py)
SERPER_API_KEY=your-serper-key-here
